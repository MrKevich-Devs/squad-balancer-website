---
import { Play, Sparkles } from 'lucide-react';
---

<section class="relative pt-32 pb-20 overflow-hidden">
  <!-- Background Glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-96 bg-brand-primary/10 blur-[120px] rounded-full -z-10"></div>
  
  <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-2 gap-12 items-center">
    <div class="text-center lg:text-left">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-brand-primary text-xs font-bold uppercase tracking-wider mb-6">
        <Sparkles size={14} />
        ¡Equipos Justos, Partidos Épicos!
      </div>
      
      <h1 class="text-5xl lg:text-7xl font-bold leading-[1.1] mb-6 text-white">
        Armá equipos <br /> equilibrados en <span class="text-brand-primary">segundos.</span>
      </h1>
      
      <p class="text-lg text-slate-300 mb-10 max-w-xl mx-auto lg:mx-0">
        La herramienta inteligente para capitanes. SquadBalancer está en **fase Alpha** y ya te ayuda a distribuir jugadores de forma justa basándose en sus habilidades.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
        <a 
          href="#download" 
          class="w-full sm:w-auto bg-brand-primary text-brand-bg px-8 py-4 rounded-2xl font-bold text-lg flex items-center justify-center gap-2 hover:bg-brand-primary-dark transition-all hover:shadow-glow-primary active:scale-95"
        >
          <Play size={20} fill="currentColor" />
          Descargar ahora
        </a>
        <a 
          href="#features" 
          class="w-full sm:w-auto bg-white/5 border border-white/10 text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-white/10 transition-all active:scale-95"
        >
          Ver funciones
        </a>
      </div>
      
      <div class="mt-10 flex items-center justify-center lg:justify-start gap-8">
        <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Optimizado para</div>
        <span class="font-black text-slate-300 tracking-tighter text-xl italic uppercase">Fútbol 5 / 7 / 11</span>
      </div>
    </div>
    
    <div class="relative">
      <!-- Animated circles background -->
      <div class="absolute inset-0 bg-brand-primary/5 rounded-full blur-3xl animate-pulse"></div>
      
      <div class="relative z-10 animate-float">
        <img 
          src={import.meta.env.BASE_URL + "/hero-mockup.png"} 
          alt="SquadBalancer App Mockup" 
          class="w-full max-w-[450px] mx-auto drop-shadow-[0_20px_50px_rgba(16,185,129,0.2)]"
        />
      </div>
      
      <!-- Stats Badge -->
      <div class="absolute bottom-10 -left-4 md:-left-8 glass-card p-4 rounded-2xl animate-bounce-slow z-20">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-brand-accent rounded-full flex items-center justify-center shadow-glow-accent text-white">
             ⚖️
          </div>
          <div>
            <div class="text-[10px] text-slate-400 uppercase font-bold tracking-widest">Algoritmo</div>
            <div class="text-sm font-bold text-white">Equilibrio Real</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
  
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .animate-bounce-slow {
    animation: bounce-slow 4s ease-in-out infinite;
  }
</style>
